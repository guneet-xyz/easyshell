{
  "name": "@easyshell/runner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "build": "pnpm exec esbuild src/index.ts --bundle --platform=node --outfile=runner.cjs --external:better-sqlite3 --external:pino --external:pino-pretty --external:thread-stream",
    "start": "node runner.cjs",
    "dev": "pnpm run build && pnpm run start",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@easyshell/logger": "workspace:*",
    "@t3-oss/env-core": "^0.12.0",
    "@trpc/client": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "better-sqlite3": "^11.0.0",
    "pino": "^9.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.17.16",
    "@vitest/coverage-v8": "^3.0.0",
    "esbuild": "^0.27.3",
    "pino-pretty": "^11.0.0",
    "tsx": "^4.19.3",
    "vitest": "^3.0.0"
  }
}
