{
  "name": "@easyshell",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "cache": "pnpm --filter @easyshell/problems run cache:website && pnpm --filter @easyshell/problems run cache:submission-manager && pnpm --filter @easyshell/problems run cache:cron",
    "db:generate": "infisical run --env=dev -- pnpm exec drizzle-kit generate",
    "db:migrate": "infisical run --env=dev -- pnpm exec drizzle-kit migrate",
    "dev:cron": "infisical run --env=dev -- pnpm --filter @easyshell/cron run dev",
    "dev:mustang": "infisical run --env=dev -- go run -C apps/mustang .",
    "dev:submission-manager": "infisical run --env=dev -- pnpm --filter @easyshell/submission-manager run dev",
    "dev:website": "infisical run --env=dev -- pnpm --filter @easyshell/website run dev",
    "docker:build": "infisical run --env=dev -- docker compose build",
    "docker:up": "infisical run --env=dev -- docker compose up -d",
    "format:check": "pnpm exec prettier --check . && gofmt -l -s .",
    "format:write": "pnpm exec prettier --write . && gofmt -w -s .",
    "lint": "pnpm run lint:tsc && pnpm run lint:next",
    "lint:next": "pnpm --filter @easyshell/website run lint",
    "lint:tsc": "pnpm exec tsc --noEmit",
    "problems:build": "infisical run --env=dev -- pnpm --filter @easyshell/problems run build",
    "problems:push": "infisical run --env=dev -- pnpm --filter @easyshell/problems run push",
    "test": "infisical run --env=dev -- pnpm --filter @easyshell/problems run test",
    "trigger:cleanup": "infisical run --env=dev -- pnpm --filter @easyshell/cron run trigger:cleanup",
    "trigger:pool": "infisical run --env=dev -- pnpm --filter @easyshell/cron run trigger:pool"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.5.3",
    "prettier-plugin-packagejson": "^2.5.22",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "^4.19.3",
    "typescript": "5.7.3"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "pnpm": {
    "overrides": {
      "@esbuild-kit/core-utils>esbuild": ">=0.25.0",
      "ajv@<6.14.0": "~6.14.0",
      "brace-expansion@>=2 <2.0.3": ">=2.0.3",
      "brace-expansion@<2": ">=1.1.13",
      "flatted": ">=3.4.2",
      "minimatch@>=9 <9.0.7": ">=9.0.7",
      "minimatch@<4": ">=3.1.4",
      "picomatch@>=4 <4.0.4": ">=4.0.4",
      "yaml@>=2 <2.8.3": ">=2.8.3"
    }
  }
}
